<x-filament-panels::page>
<div>
<style>
/* ─── Animaciones entrada ─────────────────────────────── */
@keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0);    }
}
@keyframes scaleIn {
    from { opacity: 0; transform: scale(0.88); }
    to   { opacity: 1; transform: scale(1);    }
}
@keyframes growBar {
    from { width: 0 !important; }
    to   { width: var(--w); }
}
@keyframes pulseSoft {
    0%, 100% { box-shadow: 0 0 0 0 rgba(99,102,241,.35); }
    50%       { box-shadow: 0 0 0 8px rgba(99,102,241,0);  }
}

.anim-fade-up  { animation: fadeUp  .55s ease both; }
.anim-scale-in { animation: scaleIn .45s ease both; }
.delay-1  { animation-delay: .08s; }
.delay-2  { animation-delay: .16s; }
.delay-3  { animation-delay: .24s; }
.delay-4  { animation-delay: .32s; }
.delay-5  { animation-delay: .40s; }
.delay-6  { animation-delay: .48s; }

.stat-bar {
    width: 0;
    animation: growBar .9s cubic-bezier(.25,.46,.45,.94) forwards;
}
.bd-1 { animation-delay: .20s; }
.bd-2 { animation-delay: .35s; }
.bd-3 { animation-delay: .50s; }
.bd-4 { animation-delay: .65s; }
.bd-5 { animation-delay: .80s; }
.bd-6 { animation-delay: .95s; }
.bd-7 { animation-delay: 1.10s; }
.bd-8 { animation-delay: 1.25s; }

.kpi-glow { animation: pulseSoft 2.5s ease-in-out infinite; }

.card-hover {
    transition: transform .2s ease, box-shadow .2s ease;
}
.card-hover:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px -4px rgba(0,0,0,.12);
}

/* ─── Print / PDF ─────────────────────────────────────── */
@media print {
    .no-print  { display: none !important; }
    body, html { background: white !important; }
    .anim-fade-up, .anim-scale-in { animation: none !important; opacity: 1 !important; }
    .stat-bar { animation: none !important; width: var(--w) !important; }
    table thead tr { background: #4F46E5 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    table thead th { color: white !important; }
}
</style>

