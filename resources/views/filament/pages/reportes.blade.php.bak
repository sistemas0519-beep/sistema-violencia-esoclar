@php
    $estadosData = [
        ['label' => 'Pendientes', 'val' => $r['pendiente'],  'bar' => 'bg-amber-400',   'dot' => 'bg-amber-400',   'txt' => 'text-amber-600 dark:text-amber-400',   'hex' => '#f59e0b', 'icon' => '⏳'],
        ['label' => 'En Proceso', 'val' => $r['en_proceso'], 'bar' => 'bg-blue-500',    'dot' => 'bg-blue-500',    'txt' => 'text-blue-600 dark:text-blue-400',     'hex' => '#3b82f6', 'icon' => '🔄'],
        ['label' => 'Resueltos',  'val' => $r['resuelto'],   'bar' => 'bg-emerald-500', 'dot' => 'bg-emerald-500', 'txt' => 'text-emerald-600 dark:text-emerald-400','hex' => '#10b981', 'icon' => '✅'],
        ['label' => 'Cerrados',   'val' => $r['cerrado'],    'bar' => 'bg-gray-400',    'dot' => 'bg-gray-400',    'txt' => 'text-gray-500 dark:text-gray-400',     'hex' => '#6b7280', 'icon' => '🔒'],
    ];
    $totalBase = $r['total'] ?: 1;
    $conicParts = [];
    $off = 0;
    foreach ($estadosData as $e) {
        $p = $r['total'] > 0 ? round(($e['val'] / $r['total']) * 100, 2) : 0;
        $conicParts[] = "{$e['hex']} {$off}% " . ($off + $p) . "%";
        $off += $p;
    }
    $conicGrad = implode(', ', $conicParts) ?: '#e5e7eb 0% 100%';
@endphp

